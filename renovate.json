{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "enabledManagers": [
    "dockerfile",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^hindsight\\/config\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>[0-9]+\\\\.[0-9]+\\\\.[0-9]+)"
      ],
      "depNameTemplate": "ghcr.io/vectorize-io/hindsight",
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": [
        "ghcr.io/vectorize-io/hindsight"
      ],
      "groupName": "Hindsight upstream version",
      "commitMessageTopic": "Hindsight upstream",
      "automerge": false,
      "labels": [
        "dependencies"
      ]
    }
  ]
}